# MyOSS 环境变量配置示例
# 复制此文件为 .env 并填入真实的配置值
# cp .env.example .env

# 阿里云 OSS 配置
# ⚠️ 重要：不要将 .env 文件提交到 Git 仓库！

# OSS AccessKey ID (在阿里云控制台获取)
# 获取地址：https://ram.console.aliyun.com/manage/ak
OSS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID

# OSS AccessKey Secret (在阿里云控制台获取)
OSS_ACCESS_KEY_SECRET=YOUR_ACCESS_KEY_SECRET

# OSS  Endpoint (根据 Bucket 所在区域选择)
# 杭州区域：oss-cn-hangzhou.aliyuncs.com
# 北京区域：oss-cn-beijing.aliyuncs.com
# 上海区域：oss-cn-shanghai.aliyuncs.com
# 深圳区域：oss-cn-shenzhen.aliyuncs.com
# 更多区域请参考：https://help.aliyun.com/document_detail/31837.html
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# OSS Bucket 名称 (默认使用的 Bucket)
OSS_BUCKET_NAME=lwmedia

# Flask 配置 (可选)
FLASK_ENV=production
FLASK_DEBUG=0
